# wired-dots — AUR packages (installed via paru or yay)

# Screenshot
hyprshot

# Logout / launcher (not in official repos)
wlogout

# GTK theme engine (not in official repos)
gtk-engine-murrine

# Browser — picked at install time via --with-browser (default: brave-bin).
# Installed dynamically by 03f_aur_packages.sh from $WIRED_BROWSER.

# Themes
tokyonight-gtk-theme-git
tela-circle-icon-theme-dracula
phinger-cursors-dark

# Fonts (those not in core)
redhat-fonts                 # Red Hat Display/Text/Mono — for hyprlock

# Kvantum theme
kvantum-theme-tokyo-night

