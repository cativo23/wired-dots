# OS / editor
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Machine-local configs
hypr/monitors.conf
zsh/user.local.zsh

# Installer state
.cache/
scripts/migrations/.applied

# Stale artifacts from pre-PR-G installs (kept for migration cleanup; new
# installs symlink these files into ~/.config/waybar/ instead of writing
# them into the source dir).
waybar/config.jsonc
waybar/style.css
waybar/defaults.css

# Hyprland user-choice overrides (generated by 02b_user_choices.sh)
hypr/local-overrides.conf

# Audit/Carlos-local notes (kept out of repo by default)
docs/CONFIG-AUDIT.md

# Build artifacts
*.log
*.bak

# Secrets (defense in depth — repo should never contain these)
.env*
*.pem
*.key
id_rsa*
id_ed25519*

# Screenshots raw sources
docs/screenshots/*.kra
docs/screenshots/*.xcf

# Package caches
source/wallpapers/*.part
*.pkg.tar.zst
