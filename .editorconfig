# wired-dots — EditorConfig (https://editorconfig.org/)
root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yml,yaml,toml,json,jsonc}]
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 4

[Makefile]
indent_style = tab
