{
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["箚깯", "箚깱", "箚깲"],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "on-click": "brightnessctl set 50%",
    "min-length": 6,
    "tooltip": true,
    "tooltip-format": "Backlight: {percent}%\nScroll: 짹5%\nClick: reset to 50%"
  }
}
