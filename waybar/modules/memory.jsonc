{
  "memory": {
    "interval": 10,
    "states": { "warning": 70, "critical": 90 },
    "format": "󰾆 {used:0.1f}G",
    "format-warning": "󰾅 {used:0.1f}G",
    "format-critical": " {used:0.1f}G",
    "format-alt": "󰾆 {percentage}%",
    "max-length": 10,
    "tooltip": true,
    "tooltip-format": "Memory: {percentage}%\nUsed: {used:0.2f}G / {total:0.2f}G\nAvailable: {avail:0.2f}G\nSwap: {swapUsed:0.2f}G / {swapTotal:0.2f}G ({swapPercentage}%)",
    "on-click": "kitty -e btop"
  }
}
